{
  "info": {
    "name": "CampusConnect API",
    "description": "Complete REST API collection for CampusConnect MERN Stack application.\n\nBase URL: http://localhost:5000\n\nAuth: After login/register, copy the token from the response and set it as a Bearer token in the Authorization header for protected routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000" },
    { "key": "token",    "value": "" },
    { "key": "user_id",  "value": "" },
    { "key": "task_id",  "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alex Johnson\",\n  \"email\": \"alex@university.edu\",\n  \"password\": \"Password1\"\n}"
            }
          }
        },
        {
          "name": "POST /api/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('user_id', json.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alex@university.edu\",\n  \"password\": \"Password1\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET /api/users (all students)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "GET /api/users/:id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users/{{user_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "PUT /api/users/:id (update profile)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/users/{{user_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alex Johnson Updated\",\n  \"email\": \"alex.updated@university.edu\"\n}"
            }
          }
        },
        {
          "name": "DELETE /api/users/:id",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/users/{{user_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "GET /api/tasks (all tasks)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/tasks",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "POST /api/tasks (create task)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.task) pm.collectionVariables.set('task_id', json.task._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/tasks",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Submit Assignment Report\",\n  \"description\": \"Complete and submit the MERN stack lab report by Friday.\",\n  \"status\": \"pending\"\n}"
            }
          }
        },
        {
          "name": "PUT /api/tasks/:id (update status)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/tasks/{{task_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in-progress\",\n  \"description\": \"Working on it now.\"\n}"
            }
          }
        },
        {
          "name": "DELETE /api/tasks/:id",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/tasks/{{task_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Announcements",
      "item": [
        {
          "name": "GET /api/announcements",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/announcements"
          }
        }
      ]
    }
  ]
}
