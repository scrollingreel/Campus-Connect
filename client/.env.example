# CampusConnect Frontend Environment Configuration Example
# Copy this file to '.env' or '.env.local' and customize variables

# Base URL pointing to the backend API.
# In development, Vite will proxy /api to http://localhost:5000, so this can be left blank or omitted.
# In production (e.g. Vercel), set this to your deployed Railway backend URL.
VITE_API_URL=https://campus-connect-production-294c.up.railway.app/api
